# Environment variables for autolabel3d
# Copy to .env and fill in your values. Never commit the filled .env file.

# nuScenes dataset root (required for nuScenes loader)
NUSCENES_DATAROOT=/path/to/nuscenes

# Dashcam video path (required for dashcam loader)
DASHCAM_VIDEO_PATH=/path/to/dashcam/video.mp4

# Optional: Weights & Biases for experiment tracking
WANDB_API_KEY=
WANDB_PROJECT=autolabel3d
